@model List<Mvc.Models.Employee>

<h2 class="mb-3">Employee Management</h2>
<form method="get" asp-action="Index" class="mb-3">
    <div style="display:flex; gap:10px;">
        <input type="text" name="search" value="@ViewBag.Search" 
               placeholder="Search by name..." class="form-control" />

        <button type="submit" class="btn btn-primary">Search</button>

        <a href="/Home/Index" class="btn btn-secondary">Reset</a>
    </div>
</form>
<form method="post" asp-action="Create" class="mb-4">
    <input type="text" name="Name" placeholder="Enter Name" required class="form-control mb-2" />
    <button type="submit" class="btn btn-success">Add</button>
</form>

<hr />

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th style="width:180px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model ?? new())
        {
            <tr>
                <td>@emp.Id</td>
                <td>@emp.Name</td>
                <td>
                    <a href="/Home/Edit/@emp.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a href="/Home/Delete/@emp.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>